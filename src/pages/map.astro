---
import Layout from '../layouts/Layout.astro';
import markersData from '../data/map-markers.json';
import routesData from '../data/map-routes.json';
---

<Layout title="台灣地圖 Map" description="以地圖視角探索 Taiwan.md 的內容脈絡">
  <div class="map-page">

    <div id="mapData" data-markers={JSON.stringify(markersData)} data-routes={JSON.stringify(routesData)} style="display:none"></div>

    <section class="map-hero">
      <div class="hero-inner">
        <p class="hero-kicker">Map View</p>
        <h1>台灣地圖</h1>
        <p class="hero-subtitle">
          用地圖視角探索台灣的文化、美食、自然與歷史節點。
        </p>
      </div>
    </section>

    <section class="map-controls">
      <div class="controls-inner">
        <div class="filter-section">
          <h3>區域篩選</h3>
          <div class="filter-buttons" id="regionFilters">
            <button class="filter-btn active" data-filter="all">全部</button>
            <button class="filter-btn" data-filter="north">北部</button>
            <button class="filter-btn" data-filter="central">中部</button>
            <button class="filter-btn" data-filter="south">南部</button>
            <button class="filter-btn" data-filter="east">東部</button>
            <button class="filter-btn" data-filter="islands">離島</button>
          </div>
        </div>

        <div class="filter-section">
          <h3>分類篩選</h3>
          <div class="filter-buttons" id="categoryFilters">
            <button class="filter-btn active" data-filter="all">全部</button>
            <button class="filter-btn" data-filter="food">🍜 美食</button>
            <button class="filter-btn" data-filter="history">📜 歷史</button>
            <button class="filter-btn" data-filter="nature">🌿 自然</button>
            <button class="filter-btn" data-filter="culture">🎭 文化</button>
            <button class="filter-btn" data-filter="technology">💻 科技</button>
            <button class="filter-btn" data-filter="economy">📈 經濟</button>
            <button class="filter-btn" data-filter="lifestyle">🏮 生活</button>
            <button class="filter-btn" data-filter="art">🎨 藝術</button>
            <button class="filter-btn" data-filter="geography">🗺️ 地理</button>
          </div>
        </div>
      </div>
    </section>

    <section class="route-section">
      <div class="route-inner">
        <h3>🗺️ 策展路線</h3>
        <div class="route-buttons" id="routeButtons">
          <button class="route-btn active" data-route="none">一般模式</button>
          <!-- 動態生成 route buttons -->
        </div>
        <div class="route-info" id="routeInfo" style="display:none">
          <p class="route-desc" id="routeDesc"></p>
          <div class="route-stops" id="routeStops"></div>
        </div>
      </div>
    </section>

    <section class="map-body">
      <div class="map-canvas">
        <svg id="taiwanMap" viewBox="0 0 800 1000" class="taiwan-svg">
          <defs>
            <linearGradient id="taiwanGradient" x1="0%" y1="0%" x2="0%" y2="100%">
              <stop offset="0%" stop-color="#dcfce7"></stop>
              <stop offset="50%" stop-color="#bbf7d0"></stop>
              <stop offset="100%" stop-color="#86efac"></stop>
            </linearGradient>
          </defs>
          <!-- zoom group wraps both counties and markers -->
          <g id="zoomGroup">
            <g id="taiwanCounties"></g>
            <g id="markers"></g>
          </g>
        </svg>

        <!-- Zoom controls -->
        <div class="zoom-controls">
          <button class="zoom-btn" id="zoomIn">＋</button>
          <button class="zoom-btn" id="zoomOut">－</button>
          <button class="zoom-btn" id="resetZoom">⌂</button>
        </div>

        <div id="tooltip" class="tooltip">
          <div class="tooltip-title"></div>
          <div class="tooltip-category"></div>
          <div class="tooltip-desc"></div>
        </div>
      </div>

      <div class="mobile-overlay" id="mobileOverlay"></div>
      <aside class="map-panel" id="infoPanel">
        <div class="panel-content" id="defaultContent">
          <h3>台灣知識地圖</h3>
          <div class="stats">
            <div class="stat-item">
              <span class="stat-number" id="totalMarkers">{markersData.length}</span>
              <span class="stat-label">個知識節點</span>
            </div>
            <div class="stat-item">
              <span class="stat-number" id="totalCategories">{[...new Set(markersData.map((m: any) => m.category))].length}</span>
              <span class="stat-label">個分類</span>
            </div>
          </div>

          <div class="category-distribution">
            <h4>分類分布</h4>
            <div class="category-list" id="categoryStats">
              <!-- 動態生成 -->
            </div>
          </div>

          <div class="panel-links">
            <a class="panel-link" href="/graph">🕸️ 知識圖譜</a>
            <a class="panel-link" href="/">🏠 首頁分類</a>
          </div>
        </div>

        <div class="panel-content article-content" id="articleContent" style="display: none;">
          <button class="back-btn" id="backBtn">← 返回</button>
          <h3 id="articleTitle"></h3>
          <div class="article-meta">
            <span class="article-category" id="articleCategory"></span>
          </div>
          <p id="articleDesc"></p>
          <a id="articleLink" class="read-more-btn">閱讀全文 →</a>
        </div>
      </aside>
    </section>
  </div>
</Layout>

<style>
  .map-page { padding-bottom: 2rem; }

  .map-hero {
    background: linear-gradient(135deg, #f0fdf4, #dcfce7, #bbf7d0);
    padding: 3rem 1.5rem 2rem;
    border-bottom: 1px solid #d1fae5;
  }
  .hero-inner { max-width: 1200px; margin: 0 auto; text-align: center; }
  .hero-kicker {
    font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.2em;
    color: #16a34a; margin-bottom: 0.5rem; font-weight: 600;
  }
  .map-hero h1 {
    font-size: 2.8rem; margin-bottom: 1rem; color: #2d5016;
    font-family: 'jf-jinxuanlatte', 'Noto Sans TC', sans-serif;
  }
  .hero-subtitle { font-size: 1.2rem; color: #15803d; max-width: 600px; margin: 0 auto; }

  .map-controls { background: #ffffff; border-bottom: 1px solid #e5e7eb; padding: 1.5rem 1rem; }
  .controls-inner {
    max-width: 1200px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 2fr; gap: 2rem; align-items: start;
  }
  .filter-section h3 { font-size: 1rem; color: #374151; margin-bottom: 0.75rem; font-weight: 600; }
  .filter-buttons { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .filter-btn {
    padding: 0.5rem 1rem; border: 1px solid #d1d5db; background: #ffffff;
    border-radius: 20px; font-size: 0.85rem; cursor: pointer; transition: all 0.2s; color: #374151;
  }
  .filter-btn:hover { border-color: #16a34a; background: #f0fdf4; }
  .filter-btn.active { background: #16a34a; border-color: #16a34a; color: white; }

  .map-body {
    max-width: 1200px; margin: 0 auto; padding: 2rem 1rem;
    display: grid; grid-template-columns: 2fr 1fr; gap: 2rem; align-items: start;
  }
  .map-canvas {
    position: relative; background: #ffffff; border: 1px solid #e5e7eb;
    border-radius: 16px; padding: 1.5rem; box-shadow: 0 4px 20px rgba(0,0,0,0.05);
  }
  .taiwan-svg {
    width: 100%; height: auto; max-height: 700px;
    cursor: grab;
  }
  .taiwan-svg:active { cursor: grabbing; }

  /* Zoom controls */
  .zoom-controls {
    position: absolute;
    bottom: 2rem;
    right: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .zoom-btn {
    width: 36px; height: 36px;
    background: white; border: 1px solid #e5e7eb;
    border-radius: 8px; cursor: pointer;
    font-size: 1.1rem; font-weight: 600;
    color: #374151; transition: all 0.2s;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 2px 6px rgba(0,0,0,0.08);
  }
  .zoom-btn:hover { background: #f0fdf4; border-color: #16a34a; color: #16a34a; }

  :global(.county) { fill: #bbf7d0; stroke: #4ade80; stroke-width: 0.8; transition: fill 0.2s; }
  :global(.county:hover) { fill: #86efac; }

  :global(.marker) {
    cursor: pointer; transition: all 0.3s ease;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2));
  }
  :global(.marker:hover) {
    filter: drop-shadow(0 4px 8px rgba(0,0,0,0.3)) brightness(1.1);
  }
  :global(.marker.hidden) { opacity: 0; pointer-events: none; }

  .tooltip {
    position: absolute; background: rgba(0,0,0,0.9); color: white;
    padding: 0.75rem; border-radius: 8px; font-size: 0.85rem;
    pointer-events: none; opacity: 0; transition: opacity 0.2s; z-index: 1000; max-width: 200px;
  }
  .tooltip-title { font-weight: 600; margin-bottom: 0.25rem; }
  .tooltip-category { font-size: 0.75rem; opacity: 0.8; margin-bottom: 0.25rem; }
  .tooltip-desc { font-size: 0.75rem; line-height: 1.3; }

  .map-panel {
    background: #ffffff; border: 1px solid #e5e7eb; border-radius: 16px;
    padding: 1.5rem; box-shadow: 0 4px 20px rgba(0,0,0,0.05); position: sticky; top: 2rem;
  }
  .panel-content h3 {
    font-size: 1.3rem; color: #2d5016; margin-bottom: 1rem;
    font-family: 'jf-jinxuanlatte', 'Noto Sans TC', sans-serif;
  }
  .stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem; }
  .stat-item { text-align: center; padding: 1rem; background: #f9fafb; border-radius: 8px; }
  .stat-number { display: block; font-size: 1.8rem; font-weight: 700; color: #16a34a; }
  .stat-label { font-size: 0.85rem; color: #6b7280; }

  .category-distribution h4 { font-size: 1rem; margin-bottom: 0.75rem; color: #374151; }
  .category-list { display: flex; flex-direction: column; gap: 0.5rem; }
  .category-item { display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; }
  .category-color { width: 12px; height: 12px; border-radius: 50%; }

  .panel-links { margin-top: 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; }
  .panel-link {
    padding: 0.75rem; background: #f3f4f6; border-radius: 8px; text-decoration: none;
    color: #374151; font-weight: 500; text-align: center; transition: background 0.2s;
  }
  .panel-link:hover { background: #e5e7eb; }

  .article-content { animation: fadeIn 0.3s ease; }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .back-btn {
    background: none; border: none; color: #6b7280; cursor: pointer;
    font-size: 0.9rem; margin-bottom: 1rem; padding: 0.5rem 0;
  }
  .back-btn:hover { color: #16a34a; }
  .article-meta { margin-bottom: 1rem; }
  .article-category {
    display: inline-block; padding: 0.25rem 0.75rem; background: #f0fdf4;
    color: #16a34a; border-radius: 20px; font-size: 0.8rem; font-weight: 500;
  }
  .read-more-btn {
    display: inline-block; margin-top: 1rem; padding: 0.75rem 1.5rem;
    background: #16a34a; color: white; text-decoration: none;
    border-radius: 8px; font-weight: 500; transition: background 0.2s;
  }
  .read-more-btn:hover { background: #15803d; }

  /* Route section styles */
  .route-section {
    padding: 1rem 1.5rem;
    background: #fafdf6;
    border-bottom: 1px solid #e5e7eb;
  }
  .route-inner {
    max-width: 1200px;
    margin: 0 auto;
  }
  .route-section h3 {
    font-size: 1rem;
    color: #2d5016;
    margin-bottom: 0.75rem;
  }
  .route-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    overflow-x: auto;
    padding-bottom: 0.5rem;
  }
  .route-btn {
    padding: 0.5rem 1rem;
    border: 2px solid #ccc;
    border-radius: 20px;
    background: white;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .route-btn:hover { 
    background: #f0f7e6; 
  }
  .route-btn.active { 
    background: #2d5016; 
    color: white; 
    border-color: #2d5016; 
  }

  .route-info {
    margin-top: 1rem;
    padding: 1rem;
    background: white;
    border-radius: 8px;
    border: 1px solid #e5e7eb;
  }
  .route-desc {
    font-size: 0.9rem;
    color: #666;
    margin-bottom: 1rem;
  }
  .route-stop-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.5rem 0;
    cursor: pointer;
    border-bottom: 1px solid #f0f0f0;
    transition: background 0.2s;
  }
  .route-stop-item:hover { 
    background: #fafdf6; 
  }
  .stop-number {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  .stop-info strong { 
    font-size: 0.9rem; 
    color: #333; 
  }
  .stop-info p { 
    font-size: 0.8rem; 
    color: #888; 
    margin-top: 0.25rem; 
  }

  /* Cluster and route line styles */
  :global(.route-line) {
    pointer-events: none;
  }
  :global(.cluster-circle) {
    transition: r 0.2s ease;
    cursor: pointer;
  }
  :global(.cluster-group:hover .cluster-circle) {
    fill: #4a7c59;
  }

  @media (max-width: 1024px) {
    .controls-inner { grid-template-columns: 1fr; gap: 1.5rem; }
    .map-body { grid-template-columns: 1fr; }
    .map-panel { position: relative; top: auto; }
  }
  @media (max-width: 768px) {
    .map-hero { padding: 2rem 1rem 1.5rem; }
    .map-hero h1 { font-size: 2.2rem; }
    .filter-buttons { justify-content: center; }
    .filter-btn { font-size: 0.8rem; padding: 0.4rem 0.8rem; }
    .route-section { padding: 0.75rem 1rem; }
    .route-buttons { flex-wrap: nowrap; overflow-x: auto; -webkit-overflow-scrolling: touch; gap: 0.4rem; }
    .route-btn { font-size: 0.78rem; padding: 0.4rem 0.75rem; flex-shrink: 0; }
    .route-info { max-height: 50vh; overflow-y: auto; }

    /* 手機版：浮動文章面板 */
    .map-panel {
      position: fixed;
      bottom: 0; left: 0; right: 0;
      z-index: 1000;
      border-radius: 16px 16px 0 0;
      box-shadow: 0 -4px 20px rgba(0,0,0,0.15);
      max-height: 60vh;
      overflow-y: auto;
      transform: translateY(100%);
      transition: transform 0.3s ease;
    }
    .map-panel.mobile-show {
      transform: translateY(0);
    }
    /* 手機版遮罩 */
    .mobile-overlay {
      display: none;
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background: rgba(0,0,0,0.3);
      z-index: 999;
    }
    .mobile-overlay.active { display: block; }
    .mobile-article-list { display: flex; flex-direction: column; gap: 0.5rem; }
    .mobile-article-item {
      display: flex; align-items: center; gap: 0.5rem;
      padding: 0.6rem 0.5rem; background: #f9fafb; border-radius: 8px;
      text-decoration: none; color: #333; font-size: 0.9rem;
    }
    .mobile-article-item:active { background: #e5e7eb; }
    .mobile-article-title { flex: 1; }
  }
</style>

<script src="https://cdn.jsdelivr.net/npm/d3@7/dist/d3.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/topojson-client@3/dist/topojson-client.min.js"></script>

<script is:inline>
  const markersData = JSON.parse(
    document.getElementById('mapData').getAttribute('data-markers')
  );
  const routesData = JSON.parse(
    document.getElementById('mapData').getAttribute('data-routes')
  );

  const categoryColors = {
    history: '#e74c3c', geography: '#2ecc71', culture: '#9b59b6', food: '#f39c12',
    art: '#e91e63', music: '#00bcd4', technology: '#3498db', nature: '#27ae60',
    people: '#ff9800', society: '#607d8b', economy: '#ff5722', lifestyle: '#8bc34a',
  };

  const categoryNames = {
    history: '📜 歷史', geography: '🗺️ 地理', culture: '🎭 文化', food: '🍜 美食',
    art: '🎨 藝術', music: '🎵 音樂', technology: '💻 科技', nature: '🌿 自然',
    people: '👥 人物', society: '⚖️ 社會', economy: '📈 經濟', lifestyle: '🏮 生活',
  };

  let activeRegionFilter = 'all';
  let activeCategoryFilter = 'all';
  let mapZoom = null;
  let svgSelection = null;
  let activeRoute = null;

  async function drawTaiwanMap() {
    try {
      const response = await fetch(
        'https://cdn.jsdelivr.net/npm/taiwan-atlas@0.0.3/counties-10t.json'
      );
      const topology = await response.json();
      const geojson = topojson.feature(topology, topology.objects.counties);
      const projection = d3.geoMercator().fitSize([800, 1000], geojson);
      const pathGenerator = d3.geoPath().projection(projection);
      
      // 保存 projection 到全域（供路線使用）
      window._mapProjection = projection;

      // 縣市名對照
      const countyToRegion = {
        '臺北市': 'north', '新北市': 'north', '基隆市': 'north',
        '桃園市': 'north', '新竹市': 'north', '新竹縣': 'north', '宜蘭縣': 'north',
        '臺中市': 'central', '彰化縣': 'central', '南投縣': 'central',
        '雲林縣': 'central', '苗栗縣': 'central',
        '嘉義市': 'south', '嘉義縣': 'south', '臺南市': 'south',
        '高雄市': 'south', '屏東縣': 'south',
        '花蓮縣': 'east', '臺東縣': 'east',
        '澎湖縣': 'islands', '金門縣': 'islands', '連江縣': 'islands'
      };

      // 畫縣市 + 熱力圖
      const group = document.getElementById('taiwanCounties');
      geojson.features.forEach((feature) => {
        const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        const d = pathGenerator(feature);
        if (!d) return;
        path.setAttribute('d', d);
        path.setAttribute('class', 'county');
        
        // 計算該縣市的 marker 數
        const countyName = feature.properties.COUNTYNAME;
        const region = countyToRegion[countyName];
        const markerCount = markersData.filter(m => m.city && countyName.includes(m.city.replace('台', '臺'))).length;
        
        // 熱力圖：marker 越多顏色越深
        const intensity = Math.min(markerCount / 15, 1); // 15 markers = 最深
        const green = Math.round(247 - intensity * 100);
        path.setAttribute('fill', `rgb(${187 - intensity * 80}, ${green}, ${208 - intensity * 80})`);
        
        path.setAttribute('stroke', '#4ade80');
        path.setAttribute('stroke-width', '0.8');
        path.setAttribute('data-county', countyName);
        path.setAttribute('data-count', markerCount);
        
        // Hover 效果
        path.addEventListener('mouseenter', () => {
          path.style.opacity = '0.8';
          path.style.cursor = 'pointer';
          const tooltip = document.getElementById('tooltip');
          tooltip.querySelector('.tooltip-title').textContent = countyName;
          tooltip.querySelector('.tooltip-category').textContent = `${markerCount} 篇相關文章`;
          tooltip.querySelector('.tooltip-desc').textContent = '點擊篩選此區域';
          tooltip.style.opacity = '1';
        });
        
        path.addEventListener('mouseleave', () => {
          path.style.opacity = '1';
          document.getElementById('tooltip').style.opacity = '0';
        });
        
        // Click 篩選該縣市
        path.addEventListener('click', () => {
          showCountyArticles(countyName, region);
        });
        
        group.appendChild(path);
      });

      // 動態產生 markers
      const markersGroup = document.getElementById('markers');
      markersData.forEach((m) => {
        const [x, y] = projection([m.lng, m.lat]);
        const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        circle.setAttribute('cx', String(x));
        circle.setAttribute('cy', String(y));
        circle.setAttribute('r', '5');
        circle.setAttribute('class', 'marker');
        circle.setAttribute('fill', categoryColors[m.category] || '#16a34a');
        circle.setAttribute('data-region', m.region);
        circle.setAttribute('data-category', m.category);
        circle.setAttribute('data-title', m.title);
        circle.setAttribute('data-link', m.link);
        circle.setAttribute('data-desc', m.desc);
        markersGroup.appendChild(circle);
      });

      // D3 zoom
      const svg = document.getElementById('taiwanMap');
      svgSelection = d3.select(svg);
      mapZoom = d3.zoom()
        .scaleExtent([1, 8])
        .on('zoom', (event) => {
          document.getElementById('zoomGroup').setAttribute('transform', event.transform);
          const scale = event.transform.k;
          document.querySelectorAll('.marker').forEach((marker) => {
            const originalR = 5;
            marker.setAttribute('r', String(originalR / scale));
          });
          // 更新 clusters
          updateClusters(event.transform.k);
        });
      svgSelection.call(mapZoom);

    } catch (err) {
      console.warn('Taiwan TopoJSON 載入失敗，使用備用輪廓', err);
      const group = document.getElementById('taiwanCounties');
      const fallback = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      fallback.setAttribute('d',
        'M400 100 C450 100, 480 130, 485 180 C490 220, 485 260, 480 300 C475 340, 470 380, 465 420 C460 460, 455 500, 450 540 C445 580, 440 620, 435 660 C430 700, 425 740, 415 780 C405 820, 390 850, 370 870 C350 890, 320 895, 290 890 C260 885, 230 875, 210 860 C190 845, 175 825, 165 800 C155 775, 150 745, 155 710 C160 675, 170 640, 175 605 C180 570, 175 535, 180 500 C185 465, 195 430, 205 395 C215 360, 225 325, 235 290 C245 255, 255 220, 270 190 C285 160, 310 135, 340 125 C370 115, 390 105, 400 100 Z'
      );
      fallback.setAttribute('fill', 'url(#taiwanGradient)');
      fallback.setAttribute('stroke', '#2d5016');
      fallback.setAttribute('stroke-width', '2');
      group.appendChild(fallback);
    }
  }

  function initMap() {
    const svg = document.getElementById('taiwanMap');
    const tooltip = document.getElementById('tooltip');
    const regionFilters = document.getElementById('regionFilters');
    const categoryFilters = document.getElementById('categoryFilters');

    // Tooltip + click
    svg.addEventListener('mouseover', (e) => {
      const marker = e.target.closest('.marker');
      if (!marker) return;
      tooltip.querySelector('.tooltip-title').textContent = marker.getAttribute('data-title');
      tooltip.querySelector('.tooltip-category').textContent = categoryNames[marker.getAttribute('data-category')] || marker.getAttribute('data-category');
      tooltip.querySelector('.tooltip-desc').textContent = marker.getAttribute('data-desc');
      tooltip.style.opacity = '1';
    });

    svg.addEventListener('mousemove', (e) => {
      const rect = svg.getBoundingClientRect();
      tooltip.style.left = e.clientX - rect.left + 10 + 'px';
      tooltip.style.top = e.clientY - rect.top - 10 + 'px';
    });

    svg.addEventListener('mouseout', (e) => {
      if (!e.target.closest('.marker')) return;
      tooltip.style.opacity = '0';
    });

    svg.addEventListener('click', (e) => {
      const marker = e.target.closest('.marker');
      if (!marker) return;
      showArticleInfo(marker);
    });

    // Zoom buttons
    document.getElementById('zoomIn').addEventListener('click', () => {
      if (svgSelection && mapZoom) {
        svgSelection.transition().duration(300).call(mapZoom.scaleBy, 1.5);
      }
    });

    document.getElementById('zoomOut').addEventListener('click', () => {
      if (svgSelection && mapZoom) {
        svgSelection.transition().duration(300).call(mapZoom.scaleBy, 0.67);
      }
    });

    document.getElementById('resetZoom').addEventListener('click', () => {
      if (svgSelection && mapZoom) {
        svgSelection.transition().duration(500).call(mapZoom.transform, d3.zoomIdentity);
      }
    });

    // Region filter
    regionFilters.addEventListener('click', (e) => {
      if (!e.target.classList.contains('filter-btn')) return;
      regionFilters.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
      e.target.classList.add('active');
      activeRegionFilter = e.target.getAttribute('data-filter');
      applyFilters();
      updateURL('region', activeRegionFilter);
    });

    // Category filter
    categoryFilters.addEventListener('click', (e) => {
      if (!e.target.classList.contains('filter-btn')) return;
      categoryFilters.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
      e.target.classList.add('active');
      activeCategoryFilter = e.target.getAttribute('data-filter');
      applyFilters();
      updateURL('category', activeCategoryFilter);
    });

    document.getElementById('backBtn').addEventListener('click', () => {
      document.getElementById('defaultContent').style.display = 'block';
      document.getElementById('articleContent').style.display = 'none';
      closeMobilePanel();
    });

    // 手機版遮罩點擊關閉
    document.getElementById('mobileOverlay').addEventListener('click', () => {
      closeMobilePanel();
    });
  }

  function openMobilePanel() {
    if (window.innerWidth <= 768) {
      document.getElementById('infoPanel').classList.add('mobile-show');
      document.getElementById('mobileOverlay').classList.add('active');
    }
  }
  function closeMobilePanel() {
    document.getElementById('infoPanel').classList.remove('mobile-show');
    document.getElementById('mobileOverlay').classList.remove('active');
  }

  function applyFilters() {
    const markers = document.querySelectorAll('.marker');
    let visibleCount = 0;
    markers.forEach((marker) => {
      const region = marker.getAttribute('data-region');
      const category = marker.getAttribute('data-category');
      const regionMatch = activeRegionFilter === 'all' || region === activeRegionFilter;
      const categoryMatch = activeCategoryFilter === 'all' || category === activeCategoryFilter;
      if (regionMatch && categoryMatch) {
        marker.classList.remove('hidden');
        visibleCount++;
      } else {
        marker.classList.add('hidden');
      }
    });
    document.getElementById('totalMarkers').textContent = visibleCount;
  }

  function showArticleInfo(marker) {
    const category = marker.getAttribute('data-category');
    document.getElementById('articleTitle').textContent = marker.getAttribute('data-title');
    document.getElementById('articleDesc').textContent = marker.getAttribute('data-desc');
    document.getElementById('articleLink').href = marker.getAttribute('data-link');

    const categoryEl = document.getElementById('articleCategory');
    categoryEl.textContent = categoryNames[category];
    categoryEl.style.background = (categoryColors[category] || '#16a34a') + '20';
    categoryEl.style.color = categoryColors[category] || '#16a34a';

    document.getElementById('defaultContent').style.display = 'none';
    document.getElementById('articleContent').style.display = 'block';
    openMobilePanel();
  }

  function showCountyArticles(countyName, region) {
    // 將該縣市的區域設為篩選器
    if (region) {
      activeRegionFilter = region;
      
      // 更新UI
      document.querySelectorAll('#regionFilters .filter-btn').forEach(btn => {
        btn.classList.remove('active');
        if (btn.getAttribute('data-filter') === region) {
          btn.classList.add('active');
        }
      });
      
      applyFilters();
    }

    // 手機版：顯示該區域的文章列表
    if (window.innerWidth <= 768) {
      const regionMarkers = markersData.filter(m => m.region === region);
      const defaultContent = document.getElementById('defaultContent');
      const articleContent = document.getElementById('articleContent');
      
      defaultContent.style.display = 'block';
      articleContent.style.display = 'none';
      
      // 更新側欄內容為文章列表
      const statsEl = defaultContent.querySelector('.stats');
      const catDist = defaultContent.querySelector('.category-distribution');
      const panelLinks = defaultContent.querySelector('.panel-links');
      
      if (statsEl) statsEl.style.display = 'none';
      if (catDist) {
        const regionName = { north: '北部', central: '中部', south: '南部', east: '東部', islands: '離島' }[region] || region;
        catDist.innerHTML = `
          <h4>${regionName}文章（${regionMarkers.length} 篇）</h4>
          <div class="mobile-article-list">
            ${regionMarkers.slice(0, 15).map(m => `
              <a href="${m.link}" class="mobile-article-item">
                <span class="category-color" style="background: ${categoryColors[m.category] || '#16a34a'}"></span>
                <span class="mobile-article-title">${m.title}</span>
              </a>
            `).join('')}
            ${regionMarkers.length > 15 ? `<p style="color:#999;font-size:0.8rem;margin-top:0.5rem">⋯及其他 ${regionMarkers.length - 15} 篇</p>` : ''}
          </div>
        `;
      }
      if (panelLinks) panelLinks.style.display = 'none';
      
      openMobilePanel();
    }
  }

  function updateStatistics() {
    // 計算分類統計
    const categoryStats = {};
    markersData.forEach(marker => {
      categoryStats[marker.category] = (categoryStats[marker.category] || 0) + 1;
    });
    
    // 排序並顯示前5個分類
    const sortedCategories = Object.entries(categoryStats)
      .sort(([,a], [,b]) => b - a)
      .slice(0, 5);
    
    const categoryStatsEl = document.getElementById('categoryStats');
    categoryStatsEl.innerHTML = sortedCategories.map(([category, count]) => `
      <div class="category-item">
        <span class="category-color" style="background: ${categoryColors[category] || '#16a34a'};"></span>
        <span>${categoryNames[category] || category} (${count})</span>
      </div>
    `).join('');
    
    // 更新總分類數
    document.getElementById('totalCategories').textContent = Object.keys(categoryStats).length;
  }

  // Phase 3: Smart Clustering
  function updateClusters(zoomScale) {
    const markersGroup = document.getElementById('markers');
    const allMarkers = markersGroup.querySelectorAll('.marker');
    const allClusters = markersGroup.querySelectorAll('.cluster-group');
    
    // 清除舊 clusters
    allClusters.forEach(c => c.remove());
    
    // Route 啟用時不做 cluster（避免衝突）
    if (activeRoute || zoomScale > 2.5) {
      // Zoom in 夠多，顯示個別 markers
      allMarkers.forEach(m => m.style.display = '');
      return;
    }
    
    // Grid clustering
    const cellSize = 60 / zoomScale; // 動態 cell size
    const cells = {};
    
    allMarkers.forEach(marker => {
      // 只 cluster 可見的 markers
      if (marker.style.display === 'none' || marker.classList.contains('hidden')) return;
      
      const cx = parseFloat(marker.getAttribute('cx'));
      const cy = parseFloat(marker.getAttribute('cy'));
      const cellKey = `${Math.floor(cx/cellSize)}_${Math.floor(cy/cellSize)}`;
      
      if (!cells[cellKey]) cells[cellKey] = [];
      cells[cellKey].push({ marker, cx, cy });
    });
    
    for (const [key, items] of Object.entries(cells)) {
      if (items.length <= 1) continue; // 不需要 cluster
      
      // 隱藏個別 markers
      items.forEach(item => item.marker.style.display = 'none');
      
      // 計算 cluster 中心
      const avgX = items.reduce((s, i) => s + i.cx, 0) / items.length;
      const avgY = items.reduce((s, i) => s + i.cy, 0) / items.length;
      
      // 建立 cluster 元素
      const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
      g.setAttribute('class', 'cluster-group');
      g.setAttribute('transform', `translate(${avgX}, ${avgY})`);
      
      const radius = Math.min(8 + items.length * 0.5, 20) / zoomScale;
      
      const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      circle.setAttribute('r', String(radius));
      circle.setAttribute('fill', '#2d5016');
      circle.setAttribute('fill-opacity', '0.85');
      circle.setAttribute('stroke', 'white');
      circle.setAttribute('stroke-width', String(1.5 / zoomScale));
      circle.setAttribute('class', 'cluster-circle');
      
      const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      text.setAttribute('text-anchor', 'middle');
      text.setAttribute('dy', '0.35em');
      text.setAttribute('fill', 'white');
      text.setAttribute('font-size', String(Math.max(8, 11) / zoomScale));
      text.setAttribute('font-weight', '700');
      text.textContent = String(items.length);
      
      g.appendChild(circle);
      g.appendChild(text);
      
      // Click cluster → zoom in
      g.style.cursor = 'pointer';
      g.addEventListener('click', () => {
        if (svgSelection && mapZoom) {
          const svg = document.getElementById('taiwanMap');
          const [w, h] = [800, 1000];
          svgSelection.transition().duration(500).call(
            mapZoom.transform,
            d3.zoomIdentity.translate(w/2, h/2).scale(3.5).translate(-avgX, -avgY)
          );
        }
      });
      
      markersGroup.appendChild(g);
    }
  }

  // Phase 4: Route Drawing
  function drawRoute(route) {
    const markersGroup = document.getElementById('markers');
    
    // 清除舊路線
    markersGroup.querySelectorAll('.route-line, .route-stop, .route-label').forEach(el => el.remove());
    
    if (!route) {
      activeRoute = null;
      // 恢復所有 markers
      markersGroup.querySelectorAll('.marker').forEach(m => m.style.opacity = '1');
      return;
    }
    
    activeRoute = route;
    
    // 淡化非路線 markers
    markersGroup.querySelectorAll('.marker').forEach(m => m.style.opacity = '0.15');
    
    if (!window._mapProjection) {
      console.warn('Projection not available, route drawing skipped');
      return;
    }
    
    // 用 projection 轉換座標
    const points = route.stops.map(stop => {
      return window._mapProjection([stop.lng, stop.lat]);
    });
    
    // 畫連線（曲線）
    if (points.length > 1) {
      const lineGenerator = d3.line().curve(d3.curveCatmullRom.alpha(0.5));
      const pathD = lineGenerator(points);
      
      const line = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      line.setAttribute('d', pathD);
      line.setAttribute('class', 'route-line');
      line.setAttribute('fill', 'none');
      line.setAttribute('stroke', route.color);
      line.setAttribute('stroke-width', '3');
      line.setAttribute('stroke-dasharray', '8,4');
      line.setAttribute('stroke-opacity', '0.8');
      markersGroup.appendChild(line);
    }
    
    // 畫站點
    route.stops.forEach((stop, i) => {
      const [x, y] = points[i];
      
      // 站點圓
      const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      circle.setAttribute('cx', String(x));
      circle.setAttribute('cy', String(y));
      circle.setAttribute('r', '10');
      circle.setAttribute('class', 'route-stop');
      circle.setAttribute('fill', route.color);
      circle.setAttribute('stroke', 'white');
      circle.setAttribute('stroke-width', '2');
      circle.style.cursor = 'pointer';
      
      // 序號
      const num = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      num.setAttribute('x', String(x));
      num.setAttribute('y', String(y));
      num.setAttribute('text-anchor', 'middle');
      num.setAttribute('dy', '0.35em');
      num.setAttribute('fill', 'white');
      num.setAttribute('font-size', '9');
      num.setAttribute('font-weight', '700');
      num.setAttribute('class', 'route-label');
      num.textContent = String(i + 1);
      
      // Click → 顯示 stop 資訊
      circle.addEventListener('click', () => {
        showRouteStop(route, stop, i);
      });
      
      // Tooltip
      circle.addEventListener('mouseenter', (e) => {
        const tooltip = document.getElementById('tooltip');
        tooltip.querySelector('.tooltip-title').textContent = `${i+1}. ${stop.name}`;
        tooltip.querySelector('.tooltip-category').textContent = route.name;
        tooltip.querySelector('.tooltip-desc').textContent = stop.note;
        tooltip.style.opacity = '1';
      });
      
      markersGroup.appendChild(circle);
      markersGroup.appendChild(num);
    });
    
    // 更新側欄
    showRouteInfo(route);
  }
  
  function showRouteInfo(route) {
    const info = document.getElementById('routeInfo');
    const desc = document.getElementById('routeDesc');
    const stops = document.getElementById('routeStops');
    
    info.style.display = 'block';
    desc.textContent = route.description;
    
    stops.innerHTML = route.stops.map((stop, i) => `
      <div class="route-stop-item" data-index="${i}">
        <span class="stop-number" style="background:${route.color}">${i+1}</span>
        <div class="stop-info">
          <strong>${stop.name}</strong>
          <p>${stop.note}</p>
        </div>
      </div>
    `).join('');
    
    // 點擊 stop item → zoom 到該點
    stops.querySelectorAll('.route-stop-item').forEach(item => {
      item.addEventListener('click', () => {
        const idx = parseInt(item.dataset.index);
        const stop = route.stops[idx];
        const [x, y] = window._mapProjection([stop.lng, stop.lat]);
        if (svgSelection && mapZoom) {
          svgSelection.transition().duration(500).call(
            mapZoom.transform,
            d3.zoomIdentity.translate(400, 500).scale(4).translate(-x, -y)
          );
        }
      });
    });
  }
  
  function showRouteStop(route, stop, index) {
    const panel = document.getElementById('infoPanel');
    document.getElementById('defaultContent').style.display = 'none';
    document.getElementById('articleContent').style.display = 'block';
    
    document.getElementById('articleTitle').textContent = `${index+1}. ${stop.name}`;
    document.getElementById('articleDesc').textContent = stop.note;
    document.getElementById('articleLink').href = stop.link;
    
    const categoryEl = document.getElementById('articleCategory');
    categoryEl.textContent = route.name;
    categoryEl.style.background = route.color + '20';
    categoryEl.style.color = route.color;
  }
  
  function initRoutes() {
    const container = document.getElementById('routeButtons');
    routesData.forEach(route => {
      const btn = document.createElement('button');
      btn.className = 'route-btn';
      btn.dataset.route = route.id;
      btn.style.borderColor = route.color;
      btn.textContent = route.name;
      container.appendChild(btn);
    });
    
    container.addEventListener('click', (e) => {
      if (!e.target.classList.contains('route-btn')) return;
      container.querySelectorAll('.route-btn').forEach(b => b.classList.remove('active'));
      e.target.classList.add('active');
      
      const routeId = e.target.dataset.route;
      if (routeId === 'none') {
        drawRoute(null);
        document.getElementById('routeInfo').style.display = 'none';
        updateURL('route', null);
      } else {
        const route = routesData.find(r => r.id === routeId);
        if (route) {
          drawRoute(route);
          updateURL('route', routeId);
        }
      }
    });
  }
  
  // Phase 5: URL Routing
  function updateURL(key, value) {
    const url = new URL(window.location);
    if (value && value !== 'all' && value !== 'none') {
      url.searchParams.set(key, value);
    } else {
      url.searchParams.delete(key);
    }
    history.replaceState(null, '', url);
  }
  
  function applyURLParams() {
    const params = new URLSearchParams(window.location.search);
    
    // Route
    const routeId = params.get('route');
    if (routeId) {
      const route = routesData.find(r => r.id === routeId);
      if (route) {
        drawRoute(route);
        // 也 activate 對應按鈕
        document.querySelector(`[data-route="${routeId}"]`)?.classList.add('active');
        document.querySelector(`[data-route="none"]`)?.classList.remove('active');
      }
    }
    
    // Region filter
    const region = params.get('region');
    if (region) {
      activeRegionFilter = region;
      document.querySelectorAll('#regionFilters .filter-btn').forEach(btn => {
        btn.classList.remove('active');
        if (btn.getAttribute('data-filter') === region) {
          btn.classList.add('active');
        }
      });
      applyFilters();
    }
    
    // Highlight specific marker
    const highlight = params.get('highlight');
    if (highlight) {
      const marker = document.querySelector(`.marker[data-title="${highlight}"]`);
      if (marker) {
        marker.setAttribute('r', '12');
        marker.setAttribute('stroke', '#ff0000');
        marker.setAttribute('stroke-width', '3');
        // Zoom to it
        const cx = parseFloat(marker.getAttribute('cx'));
        const cy = parseFloat(marker.getAttribute('cy'));
        setTimeout(() => {
          if (svgSelection && mapZoom) {
            svgSelection.transition().duration(800).call(
              mapZoom.transform,
              d3.zoomIdentity.translate(400, 500).scale(4).translate(-cx, -cy)
            );
          }
        }, 500);
      }
    }
  }

  document.addEventListener('DOMContentLoaded', async () => {
    await drawTaiwanMap();
    initMap();
    initRoutes();
    updateStatistics();
    updateClusters(1); // 初始化 clusters
    applyURLParams(); // 處理 URL 參數
  });
</script>